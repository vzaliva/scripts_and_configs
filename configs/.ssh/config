PubkeyAcceptedKeyTypes +ssh-dss

Host linux.eecs.tufts.edu
     User vzaliva
     RemoteCommand /usr/bin/fish -l
     RequestTTY yes
     ForwardAgent yes
     ForwardX11 no

Host quasar
    User vzaliva
    ProxyJump linux.eecs.tufts.edu
    ForwardAgent yes
    ForwardX11 no
    RemoteCommand /usr/bin/fish -l
    RequestTTY yes
    
Host branzino.local
     RemoteCommand /opt/homebrew/bin/fish -l
     RequestTTY yes
     ForwardAgent yes

Host branzino
     HostName gate.crocodile.org
     ForwardAgent yes
     Port 3022
     ForwardAgent yes
     RemoteCommand /opt/homebrew/bin/fish -l
     RequestTTY yes

# And connect Remmina to: localhost:5901
Host branzino-vnc
    HostName gate.crocodile.org
    Port 3022
    User lord

    LocalForward 127.0.0.1:5901 localhost:5900
    ExitOnForwardFailure yes

    RequestTTY no
    SessionType none
    RemoteCommand none

    ForwardAgent no
    ServerAliveInterval 30
    ServerAliveCountMax 3
    
