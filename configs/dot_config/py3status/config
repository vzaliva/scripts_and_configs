# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        interval = 5
        output_format = i3bar        
}

order += "keyboard_layout"
order += "volume master"
#order += "ipv6"
#order += "path_exists VPN"
order += "vpn_status"
order += "wireless _first_"
order += "ethernet _first_"
order += "battery 0"
order += "load"
order += "power_profile"
order += "clock"

volume master {
         format = "♪: %volume"
         format_muted = "♪: muted (%volume)"
         device = "default"
         mixer = "Master"
         mixer_idx = 0
         on_click 1 = "exec /usr/bin/pavucontrol"
}

wireless _first_ {
        format_up = "📶%quality at %essid"
        format_down = "📶 down"
}

ethernet _first_ {
        # if you use %speed, i3status requires root privileges
        format_up = "🖧 %speed"
        format_down = "🖧 down"
}

battery 0 {
        format = "🔋 %status %percentage %remaining"
        hide_seconds = true
        integer_battery_capacity = true
        last_full_capacity = true
        format_down = "No battery"
        status_chr = "⚇"
        status_bat = "⚡"
        status_full = "☻"
        path = "/sys/class/power_supply/BAT%d/uevent"
        low_threshold = 10
	on_click 1 = "exec --no-startup-id ~/bin/whatcable-popup 0"
}

vpn_status {
}

clock {
    format = ["{Local}", "{Europe/London}", "{America/Los_Angeles}", "{America/New_York}", "{Europe/Kyiv}", "{Asia/Tokyo}"]
    format_time = "%a %Y-%m-%d %H:%M %Z"
    color = "cyan"
}

load {
        format = "📈 %1min"
}

power_profile {
    format = "⚡ {profile}"
    cache_timeout = 10
    on_click 1 = "exec ~/bin/powerprofile-rofi"
}


keyboard_layout {
   format = "🖮: {layout}"
}

